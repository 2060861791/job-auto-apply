{
  "manifest_version": 3,
  "name": "BOSS直聘自动投递",
  "version": "1.0.0",
  "description": "自动循环点击BOSS直聘职位列表中的「立即沟通」按钮",
  "permissions": ["tabs"],
  "host_permissions": ["https://www.zhipin.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "BOSS自动投递"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.zhipin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
